// 프로필 사진(avatars/{uid}) 보안 규칙 참고용 사본.
// 이 저장소엔 Firebase CLI 프로젝트(.firebaserc/firebase.json)가 없어 자동 배포되지
// 않는다 — Firebase 콘솔 > Storage > Rules에 이 내용을 그대로 붙여넣어 적용할 것.
// 경로는 avatars/{uid} 고정(확장자 없음, 매번 같은 오브젝트를 덮어씀) —
// backend/src/http/statsRoutes.ts의 PATCH /me/avatar가 이 경로 규칙을 그대로 검증한다.
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /avatars/{uid} {
      // 프로필 사진은 게임 중 다른 참가자에게도 보여야 하므로 읽기는 공개.
      allow read: if true;
      // 쓰기는 본인 uid 경로에만, 5MB 이하 이미지 파일만 허용.
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}

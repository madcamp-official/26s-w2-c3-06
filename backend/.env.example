# 서버 포트
PORT=3000

# 로컬 Postgres (docker-compose 기준). 배포 시 Railway가 자동 주입.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/liar_game"

# Anthropic Claude API 키
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI API 키
OPENAI_API_KEY="sk-proj-..."

# 게임에 실제로 사용할 LLM provider — anthropic | openai
LLM_PROVIDER=anthropic

# Firebase Admin 서비스 계정 키 경로 (handshake ID 토큰 검증용)
GOOGLE_APPLICATION_CREDENTIALS="./firebase-service-account.json"

# Railway 등 파일 업로드가 안 되는 배포 환경에서는 위 GOOGLE_APPLICATION_CREDENTIALS
# 대신 서비스 계정 JSON 전체를 이 변수에 한 줄 문자열로 넣는다. docker-entrypoint.sh가
# 컨테이너 시작 시 이 값을 파일로 풀어써서 GOOGLE_APPLICATION_CREDENTIALS를 자동 설정한다.
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

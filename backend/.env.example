# 서버 포트
PORT=3000

# 로컬 Postgres (docker-compose 기준). 배포 시 Railway가 자동 주입.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/liar_game"

# Anthropic Claude API 키
ANTHROPIC_API_KEY="sk-ant-..."

# Firebase Admin 서비스 계정 키 경로 (handshake ID 토큰 검증용)
GOOGLE_APPLICATION_CREDENTIALS="./firebase-service-account.json"
